{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sociopulse.ru/schemas/survey-1.0.json",
  "title": "СоциоПульс survey definition",
  "description": "Structural validation for a survey graph. Graph-level constraints (start uniqueness, reachability, no-cycle-without-exit, dangling edges, DSL forward refs) are enforced by the in-process validator, not this schema.",
  "type": "object",
  "required": ["version", "primary_mode", "nodes"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$",
      "description": "Semantic-ish major.minor (e.g. \"1.0\")."
    },
    "primary_mode": {
      "enum": ["form", "flow"],
      "description": "Delivery mode; fixed for the lifetime of the survey."
    },
    "metadata": {
      "type": "object",
      "description": "Free-form tenant-supplied metadata; not interpreted by the runtime."
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/node" }
    }
  },
  "$defs": {
    "node": {
      "type": "object",
      "required": ["id", "kind"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9_-]+$",
          "minLength": 1,
          "maxLength": 64
        },
        "kind": {
          "enum": [
            "start",
            "intro",
            "question",
            "text-block",
            "success-end",
            "refusal-end",
            "condition",
            "jump"
          ]
        },
        "title": { "type": "string" },
        "body": { "type": "string" },
        "ui": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "x": { "type": "number" },
            "y": { "type": "number" }
          }
        },
        "question_type": {
          "enum": ["single", "multi", "number", "text", "select"]
        },
        "options": {
          "type": "array",
          "items": { "$ref": "#/$defs/option" }
        },
        "min": { "type": "number" },
        "max": { "type": "number" },
        "required": { "type": "boolean" },
        "next": {
          "type": "array",
          "items": { "$ref": "#/$defs/edge" }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "kind": { "const": "question" } },
            "required": ["kind"]
          },
          "then": { "required": ["question_type"] }
        },
        {
          "if": {
            "properties": {
              "kind": { "const": "question" },
              "question_type": { "enum": ["single", "multi", "select"] }
            },
            "required": ["kind", "question_type"]
          },
          "then": {
            "required": ["options"],
            "properties": {
              "options": { "minItems": 1 }
            }
          }
        }
      ]
    },
    "option": {
      "type": "object",
      "required": ["id", "label"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9_-]+$"
        },
        "label": { "type": "string" },
        "value": {
          "oneOf": [
            { "type": "string" },
            { "type": "number" },
            { "type": "boolean" }
          ]
        }
      }
    },
    "edge": {
      "type": "object",
      "required": ["to"],
      "additionalProperties": false,
      "properties": {
        "to": { "type": "string" },
        "when": {
          "type": "string",
          "description": "Optional expr-lang predicate. The graph validator parses and whitelists identifiers."
        }
      }
    }
  }
}
