# Go build artifacts
/bin/
/dist/
*.exe
*.test
*.out
coverage.txt
coverage.html

# Go module cache (when vendored locally)
/vendor/

# IDE / editor
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# Environment / secrets
.env
.env.*
!.env.example
*.pem
*.key
*.crt

# Frontend
/web/node_modules/
/web/dist/
/web/.vite/
/web/coverage/

# Local dev databases / volumes
/data/
/var/

# Generated docs/openapi
/docs/api/generated/

# tmp / scratch
/tmp/
*.bak
/api

# protoc plugin trampolines generated on demand by `make proto-*` targets.
# The actual binaries resolve via `go tool` (Go 1.24+ tool directive); the
# tiny shell scripts under this dir only adapt protoc's $PATH-lookup contract.
/.protoc-tools/
