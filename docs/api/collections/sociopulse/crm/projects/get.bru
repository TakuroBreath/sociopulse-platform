meta {
  name: Get project
  type: http
  seq: 2
}

get {
  url: {{base_url}}/api/projects/{{project_id}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

tests {
  test("200 OK on get", function() {
    expect(res.status).to.equal(200);
  });
  test("response is a ProjectDTO for the requested id", function() {
    expect(res.body).to.have.property("id");
    expect(res.body.id).to.equal(bru.getEnvVar("project_id"));
    expect(res.body).to.have.property("tenant_id");
    expect(res.body).to.have.property("code");
    expect(res.body).to.have.property("name");
    expect(res.body).to.have.property("status");
  });
}
