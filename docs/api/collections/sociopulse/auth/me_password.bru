meta {
  name: Change password (me)
  type: http
  seq: 5
}

post {
  url: {{base_url}}/api/auth/me/password
  body: json
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

headers {
  content-type: application/json
}

body:json {
  {
    "old_password": "{{admin_password}}",
    "new_password": "NewAdminPass456!"
  }
}

tests {
  test("204 No Content on successful password change", function() {
    expect(res.status).to.equal(204);
  });
}
