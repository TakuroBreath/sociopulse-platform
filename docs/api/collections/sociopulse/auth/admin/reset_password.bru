meta {
  name: Admin — reset user password
  type: http
  seq: 7
}

post {
  url: {{base_url}}/api/auth/users/{{user_id}}/reset_password
  body: none
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

tests {
  test("200 OK on reset", function() {
    expect(res.status).to.equal(200);
  });
  test("response carries the one-time temp_password", function() {
    expect(res.body).to.have.property("temp_password");
    expect(res.body.temp_password).to.be.a("string");
  });
}
